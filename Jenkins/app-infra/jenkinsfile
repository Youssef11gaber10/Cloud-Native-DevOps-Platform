pipeline {
    agent { label "agent-1" }

    parameters {
        // Step 16: repo add is only ever run when this is true. Leave false for a
        // public repo — ArgoCD reads it directly with no credentials at all.
        booleanParam(
            name: 'PRIVATE_REPO',
            defaultValue: false,
            description: 'Set to true only if the GitOps repo has become private. Controls whether "argocd repo add" runs.'
        )
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/Youssef11gaber10/Cloud-Native-DevOps-Platform.git',
            description: 'Used for "argocd repo add" when PRIVATE_REPO=true. Must match spec.source.repoURL in Argo-CD/root-app.yml.'
        )
    }

    environment {
        TF_DIR_EKS        = "Infra/app-infra/EKS-cluster"
        DEVOPS_IMAGE      = "youssef11gaber10/kops:latest"
        KOPS_CLUSTER_NAME = 'kops-argo'
        KOPS_STATE_STORE  = 's3://kops-argo-cluster-state-s3'
        AWS_REGION_KOPS        = 'eu-central-1'
        ARGOCD_EKS_CLUSTER_NAME = 'eks-prod-cluster'
        ROOT_APP_NAME     = 'root-app'

    }

    options {
        disableConcurrentBuilds()
    }


    stages {

        stage('Cleanup Before Unstash workspace 1') 
        {      
            agent { 
                docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps { 

                cleanWs(                    
                        deleteDirs: true,                    
                        disableDeferredWipeout: true                
                        )

                sh 'echo "===== Workspace after cleanup ====="'      
                sh 'echo "WORKSPACE:   ${WORKSPACE}"'     
                sh 'pwd'         
                sh 'ls -lah'      
                }        

        }
        
        stage('EKS: Terraform Fmt') {
            agent { 
                docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ])
            {
                dir("${TF_DIR_EKS}") {
                    sh 'terraform fmt -check -recursive'
                }

            }

            }
        }

        stage('EKS: Terraform Validate') {
            agent { 
                docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                {
                
                    dir("${TF_DIR_EKS}") {
                        sh '''
                            terraform init -backend=true
                            terraform validate
                        '''
                    }

                }
            }
        }

        stage('EKS: Terraform Plan') {
            agent { docker { 
                            image "${DEVOPS_IMAGE}"
                            label 'agent-1' 
                            args '-u root'
                            } 
            }
            steps {
                                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                {
                    dir("${TF_DIR_EKS}") {
                        sh 'terraform plan -out=tfplan'
                        sh 'cat tfplan'
                    }
                    // stash name: 'tfplan-eks', includes: "${TF_DIR_EKS}/tfplan" # no need to stash tfplan it already remain in workspace of container to next stage

                }
            }
        }

        // ---------- Step 5: first manual approval (before touching real infra) ----------
        stage('EKS: Manual Approval') {
            steps {
                input message: "Review the EKS plan output above. Approve apply to PRODUCTION eks-cluster?", ok: 'Apply'
            }
        }

        stage('EKS: Terraform Apply') {
            agent { docker { 
                            image "${DEVOPS_IMAGE}"
                            label 'agent-1' 
                            args '-u root'
                            } 
            }
            steps {

                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                {
                    dir("${TF_DIR_EKS}") {
                        sh 'ls -lah tfplan'
                        sh 'cat tfplan'
                        sh 'terraform apply -auto-approve tfplan'
                    }
                }
            }
        }

        // ---------- Step 4: capture Terraform outputs ----------
        // Cluster name/endpoint are needed later for `aws eks update-kubeconfig` and
        // `argocd cluster add`. None of this is secret, so a plain stashed file is fine.
        stage('EKS: Capture Terraform Outputs') {
            agent { docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps {

                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                {
                    dir("${TF_DIR_EKS}") {
                        sh '''
                            set -euo pipefail
                            terraform init -backend=true -input=false
                            {
                            echo "EKS_CLUSTER_NAME=$(terraform output -raw cluster_name)"
                            echo "EKS_API_SERVER=$(terraform output -raw cluster_endpoint)"
                            } > eks-outputs.env
                        '''
                    }
                    // stash name: 'eks-outputs', includes: "${TF_DIR_EKS}/eks-outputs.env"
                    // no need to stash eks-outputs.env it already remain in workspace of container to next stage

                }
            }
        }

        // ---------- Step 7: second manual approval, before creating the kops cluster ----------
        stage('Argo: Manual Approval') {
            steps {
                input message: "Approve creation of Argo kops cluster (${KOPS_CLUSTER_NAME})?", ok: 'Create'
            }
        }


        // ---------- Step 8: create the kops cluster ----------
        stage('Argo: Kops Create Cluster') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}" // pull the image first time and later it will be on agent-1 so don't change the agent
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {

                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    file(credentialsId: 'KOPS_SSH_PUBLIC_KEY', variable: 'KOPS_PUB_KEY')
                ]) 

                {
                    sh '''
                        set -euo pipefail


                        if kops get clusters >/dev/null 2>&1; then
                            echo "Cluster exists. Updating..."
                            kops update cluster \
                            --name ${KOPS_CLUSTER_NAME} \
                            --yes

                        else

                            echo "Creating cluster..."
                            kops create cluster \
                            --node-count=3 \
                            --node-size=t3.small \
                            --zones=${AWS_REGION_KOPS}a,${AWS_REGION_KOPS}b,${AWS_REGION_KOPS}c \
                            --master-size=t3.small \
                            --master-zones=${AWS_REGION_KOPS}a \
                            --ssh-public-key=${KOPS_PUB_KEY} \
                            --yes

                        fi

                        # kops export kubeconfig --admin --kubeconfig ${WORKSPACE}/kops.kubeconfig
                        kops export kubeconfig --admin  
                        kubectl config current-context
                        # make it at ~/.kube/config use it directly without export it will be at ${WORKSPACE} need to do it each container cause /root/.kube/config is not in workspace so its not shared 
                    '''
                }

            }
        }

        // ---------- Step 9: wait until the kops cluster is healthy ----------
        stage('Argo: Wait For Kops Cluster Healthy') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {

                withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ])
            {
                    sh '''
                        set -euo pipefail

                        kops validate cluster --wait 15m
                    '''
            }
            }
        }

        // ---------- Step 10-11: install ArgoCD via Helm, Service = LoadBalancer ----------
        stage('ArgoCD: Install via Helm') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {

            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ])
                {

                    sh '''
                        set -euo pipefail

                        kops export kubeconfig --admin 

                        helm repo add argo https://argoproj.github.io/argo-helm
                        helm repo update

                        helm upgrade --install argocd argo/argo-cd \
                        --namespace argocd \
                        --create-namespace \
                        --set server.service.type=LoadBalancer \
                        --wait \
                        --timeout 10m
                    '''
                }
            }
        }

        // ---------- Step 12a: wait until all ArgoCD pods are Ready ----------
        // `helm --wait` above already blocks on Deployments being Available, but this
        // is an explicit, visible check on Pod readiness before we move on.
        stage('ArgoCD: Wait For Pods Ready') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {

                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ])

                {
                    sh '''
                        set -euo pipefail

                        kops export kubeconfig --admin 

                        kubectl -n argocd wait --for=condition=Ready pod \
                        -l app.kubernetes.io/part-of=argocd,app.kubernetes.io/component!=redis-secret-init \
                        --timeout=300s
                    '''

                    
                }
            }
        }

        // ---------- Step 12b: wait for the argocd-server LoadBalancer hostname/IP ----------
        stage('ArgoCD: Wait For LoadBalancer') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }

            steps {


            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ])

            {

                sh '''
                    set -euo pipefail


                    kops export kubeconfig --admin 


                    ADDR=""
                    for i in $(seq 1 60); do
                        ADDR=$(kubectl -n argocd get svc argocd-server \
                            -o jsonpath='{.status.loadBalancer.ingress[0].hostname}{.status.loadBalancer.ingress[0].ip}' 2>/dev/null || true)

                        [ -n "$ADDR" ] && break
                        sleep 10
                    done

                    ARGOCD_PASSWORD=$(kubectl -n argocd get secret argocd-initial-admin-secret \
                    -o jsonpath='{.data.password}' | base64 -d)

                    printf 'ARGOCD_HOST=%s\nARGOCD_PASSWORD=%s\n' "$ADDR" "$ARGOCD_PASSWORD" > argocd.env
                    cat argocd.env

                    ''' 

            }
            }
        }

        // ---------- Step 13-14: get the initial admin password, argocd login ----------
        stage('ArgoCD: CLI Login') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }

            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ])

                {
                    
                    sh '''
                        set -euo pipefail
                        pwd 
                        ls -lR
]
                        ls -lah argocd.env || true
                        cat argocd.env || true


                        kops export kubeconfig --admin 

                        source ./argocd.env 
                        echo "ARGOCD_PASSWORD: $ARGOCD_PASSWORD"
                        echo "ARGOCD_HOST: $ARGOCD_HOST"

                        argocd login "$ARGOCD_HOST" \
                        --username admin \
                        --password "$ARGOCD_PASSWORD" \
                        --insecure
                    '''
                }

            }
        }

        // ---------- Step 15: register the EKS cluster with ArgoCD ----------
        // The only place in the whole pipeline that touches the EKS cluster directly —
        // `aws eks update-kubeconfig` is used solely to produce the context that
        // `argocd cluster add` then registers. --name pins the registered name to
        // match spec.destination.name in Argo-CD/root-app.yml.
        stage('ArgoCD: Register EKS Cluster') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
       
                // unstash 'eks-outputs'
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail

                        kops export kubeconfig --admin 


                        source "${TF_DIR_EKS}/eks-outputs.env" # this export the EKS_CLUSTER_NAME & EKS_API_SERVER as env variables
                        source argocd.env



                        # ArgoCD CLI needs to be logged in and pointed at the ArgoCD server
                        # for this call; KUBECONFIG here is only used by `argocd cluster add`

                        argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure


                        aws eks update-kubeconfig \
                          --region "eu-north-1" \
                          --name "$EKS_CLUSTER_NAME" \
                          --kubeconfig eks.kubeconfig

                        EKS_CONTEXT=$(KUBECONFIG=eks.kubeconfig kubectl config current-context)

                        KUBECONFIG=eks.kubeconfig argocd cluster add "$EKS_CONTEXT" \
                          --name "${ARGOCD_EKS_CLUSTER_NAME}" \
                          --yes

                        rm -f eks.kubeconfig
                    '''
                }
            }
        }

        // ---------- Step 16: register the Git repository, only if private ----------
        stage('ArgoCD: Register Git Repository') {
            when { expression { return params.PRIVATE_REPO } }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    usernamePassword(credentialsId: 'GIT_REPO_CREDENTIALS',usernameVariable: 'GIT_USERNAME',passwordVariable: 'GIT_PAT'),
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin 


                        source argocd.env

                        argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure



                        argocd repo add "${GIT_REPO_URL}" \
                            --username "$GIT_USERNAME" \
                            --password "$GIT_PAT"
                    '''
                }
            }
        }

        // ---------- Step 17: apply the Root Application ----------
        stage('ArgoCD: Apply Root Application') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                {

                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin 

                        kubectl apply -f Argo-CD/root-app.yml
                    '''
                }
            }
        }

        // ---------- Step 18: wait until the Application is Healthy and Synced ----------
        stage('ArgoCD: Wait For Application Healthy & Synced') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                // unstash 'argocd-lb-address'

                {


                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin 

                        source argocd.env

                        argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure

                        argocd app wait "${ROOT_APP_NAME}" \
                        --health \
                        --sync \
                        --timeout 300
                    '''
                }
            }
        }

        // ---------- Step 19: final verification ----------
        stage('Verify: ArgoCD State') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) 
                // unstash 'kops-kubeconfig'
                // unstash 'argocd-lb-address'
                {

                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin 

                        source argocd.env

                        argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure

                        echo "== ArgoCD Pods =="
                        kubectl get pods -n argocd

                        echo "== ArgoCD Applications (via kubectl) =="
                        kubectl get applications -n argocd

                        echo "== ArgoCD Apps (via CLI) =="
                        argocd app list

                        echo "== Root Application detail =="
                        argocd app get "${ROOT_APP_NAME}"

                        echo "===== LoadBalancer ====="
                        kubectl -n argocd get svc argocd-server

                        echo
                        echo "===== Initial Password ====="
                        kubectl -n argocd get secret argocd-initial-admin-secret \
                        -o jsonpath='{.data.password}' | base64 -d

                    '''
                }
            }
        }
    }
}