pipeline {
    agent { label "agent-1" }

    parameters {
        // Step 16: repo add is only ever run when this is true. Leave false for a
        // public repo — ArgoCD reads it directly with no credentials at all.
        booleanParam(
            name: 'PRIVATE_REPO',
            defaultValue: false,
            description: 'Set to true only if the GitOps repo has become private. Controls whether "argocd repo add" runs.'
        )
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/Youssef11gaber10/Cloud-Native-DevOps-Platform.git',
            description: 'Used for "argocd repo add" when PRIVATE_REPO=true. Must match spec.source.repoURL in Argo-CD/root-app.yml.'
        )
    }

    environment {
        TF_DIR_EKS        = "Infra/app-infra/EKS-cluster"
        KOPS_CLUSTER_NAME = 'kops-argo'
        KOPS_STATE_STORE  = 's3://kops-argo-cluster-state-s3'
        DEVOPS_IMAGE      = "youssef11gaber10/kops:latest"
        AWS_REGION        = 'eu-central-1'
        // Must match spec.destination.name in Argo-CD/root-app.yml — the pipeline
        // passes this as --name to `argocd cluster add` so the two always agree.
        ARGOCD_EKS_CLUSTER_NAME = 'eks-prod-cluster'
        ROOT_APP_NAME     = 'root-app'
    }

    options {
        disableConcurrentBuilds()
    }

    // Deliberately NO triggers {} block and NO webhook enabled on this job —
    // runs only when a human clicks "Build Now".
    // No ACTION parameter anywhere in this file — there is no destroy code path.

    stages {



stage('Preflight: Validate Jenkins Configuration') {
    steps {
        script {
            echo "========================================="
            echo "Checking Jenkins prerequisites..."
            echo "========================================="
        }

        //
        // AWS Credentials
        //
        withCredentials([
            string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
            string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
        ]) {
            sh '''
                set -e

                [ -n "$AWS_ACCESS_KEY_ID" ] || { echo "ERROR: AWS_ACCESS_KEY_ID is empty"; exit 1; }
                [ -n "$AWS_SECRET_ACCESS_KEY" ] || { echo "ERROR: AWS_SECRET_ACCESS_KEY is empty"; exit 1; }

                echo "✓ AWS credentials found"
            '''
        }

        //
        // Kops SSH Public Key
        //
        withCredentials([
            file(credentialsId: 'KOPS_SSH_PUBLIC_KEY', variable: 'KOPS_PUB_KEY')
        ]) {
            sh '''
                set -e

                [ -f "$KOPS_PUB_KEY" ] || {
                    echo "ERROR: KOPS_SSH_PUBLIC_KEY credential missing"
                    exit 1
                }

                echo "✓ Kops SSH public key found"
            '''
        }

        //
        // Git credentials (only if PRIVATE_REPO=true)
        //
        script {
            if (params.PRIVATE_REPO) {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'GIT_REPO_CREDENTIALS',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PAT'
                    )
                ]) {

                    sh '''
                        set -e

                        [ -n "$GIT_USER" ] || {
                            echo "ERROR: Git username missing"
                            exit 1
                        }

                        [ -n "$GIT_PAT" ] || {
                            echo "ERROR: Git PAT missing"
                            exit 1
                        }

                        echo "✓ Git credentials found"
                    '''
                }

            } else {
                echo "✓ Public Git repository - skipping Git credentials check"
            }
        }

        //
        // Verify required tools on the Jenkins agent
        //
        sh '''
            set -e

            echo
            echo "Checking installed tools..."

            command -v docker >/dev/null || { echo "docker not installed"; exit 1; }
            command -v git >/dev/null || { echo "git not installed"; exit 1; }

            echo "✓ docker"
            echo "✓ git"
        '''

        //
        // Verify required directories exist
        //
        sh """
            set -e

            [ -d "${TF_DIR_EKS}" ] || {
                echo "Terraform directory not found:"
                echo "${TF_DIR_EKS}"
                exit 1
            }

            [ -f "Argo-CD/root-app.yml" ] || {
                echo "Argo-CD/root-app.yml not found"
                exit 1
            }

            echo "✓ Terraform directory exists"
            echo "✓ root-app.yml exists"
        """

        //
        // Verify Docker image exists
        //

    }
}












        

