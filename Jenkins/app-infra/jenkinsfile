pipeline {
    agent { label "agent-1" }

    parameters {
        // Step 16: repo add is only ever run when this is true. Leave false for a
        // public repo — ArgoCD reads it directly with no credentials at all.
        booleanParam(
            name: 'PRIVATE_REPO',
            defaultValue: false,
            description: 'Set to true only if the GitOps repo has become private. Controls whether "argocd repo add" runs.'
        )
        string(
            name: 'GIT_REPO_URL',
            defaultValue: 'https://github.com/Youssef11gaber10/Cloud-Native-DevOps-Platform.git',
            description: 'Used for "argocd repo add" when PRIVATE_REPO=true. Must match spec.source.repoURL in Argo-CD/root-app.yml.'
        )
    }

    environment {
        TF_DIR_EKS        = "Infra/app-infra/EKS-cluster"
        DEVOPS_IMAGE      = "youssef11gaber10/kops:latest"
        KOPS_CLUSTER_NAME = 'kops-argo'
        KOPS_STATE_STORE  = 's3://kops-argo-cluster-state-s3'
        AWS_REGION_KOPS        = 'eu-central-1'
        ARGOCD_EKS_CLUSTER_NAME = 'eks-prod-cluster'
        ROOT_APP_NAME     = 'root-app'
        ARGOCD_HOST       = ''
        ARGOCD_PASSWORD   = ''
        TEST_ENV          = ''

    }

    options {
        disableConcurrentBuilds()
    }


    stages {

        stage('Cleanup Workspace') {
                steps {
                    cleanWs()
                }
            }
        stage('test passing env & stach ') {
            agent { 
                docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ])
            {
                sh 'echo "========== work space files =========="'
                sh 'ls -lR'
                sh 'echo "this is test file want pass to anothe stage " >> gaber-out.txt '
                sh '${TEST_ENV}="THIS IS TEST ENV VARIABLE PASS FROM PREV STAGE "'

                dir("${TF_DIR_EKS}") {
                    sh 'echo "========== cd to ${TF_DIR_EKS} =========="'
                    sh 'ls -lR'
                    sh 'echo "this is test file want pass to anothe stage " >> gaber-in.txt '
                }

            }

            stash name: 'gaber1', includes: "gaber-out.txt"
            stash name: 'gaber2', includes: "${TF_DIR_EKS}/gaber-in.txt"


            }
        }


        stage('recieve  env & stach ') {
            agent { 
                docker { 
                            image 'hashicorp/terraform:1.15.8'
                            label 'agent-1' 
                            args '--entrypoint=""'
                            } 
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ])
            {
                unstash 'gaber1'
                sh "ls -lR"
                sh 'cat gaber-out.txt'
                dir("${TF_DIR_EKS}") {
                    unstash 'gaber2'
                    sh "ls -lR"
                    sh 'cat gaber-in.txt'
                }

            }

            }
        }


