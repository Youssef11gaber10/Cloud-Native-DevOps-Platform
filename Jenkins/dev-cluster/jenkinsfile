pipeline {
    agent { label "agent-1" }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: 'apply = create/update the dev kops cluster. destroy = tear it down (requires approval).'
        )
    }

    environment {
        DEVOPS_IMAGE          = "youssef11gaber10/kops:latest"
        KOPS_CLUSTER_NAME     = 'kops-dev'
        KOPS_STATE_STORE      = 's3://kops-dev-cluster-state-s3'
        AWS_REGION_KOPS       = 'eu-central-1'
    }

    options {
        disableConcurrentBuilds()
    }


    stages {

        stage('Cleanup Workspace') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                cleanWs(
                    deleteDirs: true,
                    disableDeferredWipeout: true
                )
                sh 'echo "===== Workspace after cleanup ====="'
                sh 'pwd'
                sh 'ls -lah'
            }
        }

        stage('Pre-check: AWS + state store reachable') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail

                        echo "==> Pre-check: AWS credentials valid"
                        aws sts get-caller-identity >/dev/null

                        echo "==> Pre-check: kops state store bucket reachable"
                        BUCKET=$(echo ${KOPS_STATE_STORE} | sed 's|s3://||')
                        aws s3api head-bucket --bucket "$BUCKET" \
                            || { echo "ERROR: cannot reach kops state store bucket ${KOPS_STATE_STORE}" >&2; exit 1; }
                    '''
                }
            }
        }

        // ---------- Manual approval, only required for destroy ----------
        stage('Manual Approval for Destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                input message: "Confirm DESTROY of dev kops cluster '${KOPS_CLUSTER_NAME}'? This is irreversible.", ok: 'Destroy it'
            }
        }

        // ---------- APPLY: create the cluster if it doesn't exist, update it if it does ----------
        stage('Kops: Create/Update Cluster') {
            when {
                expression { params.ACTION == 'apply' }
            }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY'),
                    file(credentialsId: 'KOPS_SSH_PUBLIC_KEY', variable: 'KOPS_PUB_KEY')
                ]) {
                    sh '''
                        set -euo pipefail

                        [ -s "${KOPS_PUB_KEY}" ] || { echo "ERROR: SSH public key credential is empty or missing" >&2; exit 1; }

                        if kops get cluster --name "${KOPS_CLUSTER_NAME}" >/dev/null 2>&1; then
                            echo "Cluster ${KOPS_CLUSTER_NAME} already exists — updating..."
                            kops update cluster --name "${KOPS_CLUSTER_NAME}" --yes
                        else
                            echo "Creating cluster ${KOPS_CLUSTER_NAME}..."
                            kops create cluster \
                              --name="${KOPS_CLUSTER_NAME}" \
                              --node-count=3 \
                              --node-size=t3.small \
                              --zones=${AWS_REGION_KOPS}a,${AWS_REGION_KOPS}b,${AWS_REGION_KOPS}c \
                              --master-size=t3.small \
                              --master-zones=${AWS_REGION_KOPS}a \
                              --ssh-public-key=${KOPS_PUB_KEY} \
                              --yes
                        fi

                        kops export kubeconfig --admin
                        kubectl config current-context
                    '''
                }
            }
        }

        stage('Kops: Wait For Cluster Healthy') {
            when {
                expression { params.ACTION == 'apply' }
            }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin
                        kops validate cluster --wait 15m
                    '''
                }
            }
        }

        stage('Kops: Verify Cluster (apply)') {
            when {
                expression { params.ACTION == 'apply' }
            }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail
                        kops export kubeconfig --admin

                        echo "== Nodes =="
                        kubectl get nodes -o wide

                        echo "== Cluster info =="
                        kubectl cluster-info
                    '''
                }
            }
        }

        // ---------- DESTROY: tear down the cluster (after approval above) ----------
        stage('Kops: Pre-check cluster exists (destroy)') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail
                        if ! kops get cluster --name "${KOPS_CLUSTER_NAME}" >/dev/null 2>&1; then
                            echo "ERROR: cluster ${KOPS_CLUSTER_NAME} does not exist in ${KOPS_STATE_STORE} — nothing to destroy." >&2
                            exit 1
                        fi
                        echo "Confirmed cluster ${KOPS_CLUSTER_NAME} exists — proceeding to destroy."
                    '''
                }
            }
        }

        stage('Kops: Delete Cluster') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail
                        kops delete cluster --name "${KOPS_CLUSTER_NAME}" --yes
                    '''
                }
            }
        }


        stage('ArgoCD: Fetch Login Info') {
            agent {
                docker {
                    image "${DEVOPS_IMAGE}"
                    label 'agent-1'
                    args '-u root'
                }
            }
            steps {
                withCredentials([
                    string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh '''
                        set -euo pipefail

                        KOPS_STATE_STORE=${KOPS_ARGO_STATE_STORE} kops export kubeconfig --name "${KOPS_ARGO_CLUSTER_NAME}" --admin --kubeconfig ./argo.kubeconfig
                        export KUBECONFIG=./argo.kubeconfig

                        ADDR=""
                        for i in $(seq 1 30); do
                            ADDR=$(kubectl -n argocd get svc argocd-server \
                                -o jsonpath='{.status.loadBalancer.ingress[0].hostname}{.status.loadBalancer.ingress[0].ip}' 2>/dev/null || true)
                            [ -n "$ADDR" ] && break
                            sleep 10
                        done
                        [ -n "$ADDR" ] || { echo "ERROR: could not fetch ArgoCD LoadBalancer address" >&2; exit 1; }

                        ARGOCD_PASSWORD=$(kubectl -n argocd get secret argocd-initial-admin-secret \
                            -o jsonpath='{.data.password}' | base64 -d)

                        printf 'ARGOCD_HOST=%s\nARGOCD_PASSWORD=%s\n' "$ADDR" "$ARGOCD_PASSWORD" > argocd.env
                    '''
                }
            }
        }


        stage('ArgoCD: Register Dev Cluster') {
        when {
            expression { params.ACTION == 'apply' }
        }
        agent {
            docker {
                image "${DEVOPS_IMAGE}"
                label 'agent-1'
                args '-u root'
            }
        }
        steps {
            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh '''
                    set -euo pipefail

                    echo "==> Export DEV cluster kubeconfig - this is the cluster argocd cluster add will register"
                    kops export kubeconfig --name "${KOPS_CLUSTER_NAME}" --admin --kubeconfig ./dev.kubeconfig
                    DEV_CONTEXT=$(KUBECONFIG=./dev.kubeconfig kubectl config current-context)

                    echo "==> Log in to the ArgoCD API server (running on the Argo cluster's LoadBalancer)"
                    . "./argocd.env"
                    argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure

                    echo "==> Register the dev cluster with ArgoCD"
                    KUBECONFIG=./dev.kubeconfig argocd cluster add "$DEV_CONTEXT" \
                        --name "${ARGOCD_DEV_CLUSTER_NAME}" \
                        --yes

                    rm -f ./dev.kubeconfig
                    echo "Dev cluster '${ARGOCD_DEV_CLUSTER_NAME}' registered with ArgoCD."
                '''
            }
        }
    }



        stage('ArgoCD: Deregister Dev Cluster') {
        when {
            expression { params.ACTION == 'destroy' }
        }
        agent {
            docker {
                image "${DEVOPS_IMAGE}"
                label 'agent-1'
                args '-u root'
            }
        }
        steps {
            withCredentials([
                string(credentialsId: 'AWS_ACCESS_KEY_ID', variable: 'AWS_ACCESS_KEY_ID'),
                string(credentialsId: 'AWS_SECRET_ACCESS_KEY', variable: 'AWS_SECRET_ACCESS_KEY')
            ]) {
                sh '''
                    set -euo pipefail

                    echo "==> Log in to the ArgoCD API server"
                    . "./argocd.env"
                    argocd login "$ARGOCD_HOST" --username admin --password "$ARGOCD_PASSWORD" --insecure

                    echo "==> Deregister the dev cluster from ArgoCD (safe no-op if already gone)"
                    argocd cluster rm "${ARGOCD_DEV_CLUSTER_NAME}" || echo "Cluster ${ARGOCD_DEV_CLUSTER_NAME} was not registered, nothing to remove."
                '''
            }
        }
    }   









    }
}